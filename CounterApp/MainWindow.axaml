<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CounterApp.MainWindow"
    Width="400"
    Height="250"
    Title="カウンター">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="16">

        <TextBlock
            x:Name="CountText"
            Text="0"
            FontSize="40"
            HorizontalAlignment="Center" />

        <Button
            Content="カウントアップ"
            Click="CountButton_Click"
            HorizontalAlignment="Center" />

    </StackPanel>
</Window>